// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum QUYEN {
  ADMIN
  USER
}

enum GIOI_TINH {
  NAM
  NU
  KHAC
}

enum TRANG_THAI_LAM_VIEC {
  DANG_LAM_VIEC
  THU_VIEC
  NGHI_VIEC
}

enum HINH_THUC_LAM_VIEC {
  TOAN_THOI_GIAN
  BAN_THOI_GIAN
  THU_VIEC
}

model DANH_MUC_CHUC_VU {
  ID_CV    String  @id @map("_id")
  TEN_CV   String  @unique
  HIEU_LUC Boolean @default(true)
}

model DANH_MUC_PHONG_BAN {
  ID_PB    String  @id @map("_id")
  TEN_PB   String  @unique
  HIEU_LUC Boolean @default(true)
}

model NGUOI_DUNG {
  ID_NGUOI_DUNG String @id @default(auto()) @map("_id") @db.ObjectId
  TAI_KHOAN     String @unique
  MAT_KHAU      String
  QUYEN         QUYEN  @default(USER)

  NHAN_VIEN NHAN_VIEN[]
}

model NHAN_VIEN {
  ID_NHAN_VIEN String @id @default(auto()) @map("_id") @db.ObjectId
  MA_NV        String @unique
  HO_VA_TEN    String

  GIOI_TINH          GIOI_TINH
  NGAY_SINH          DateTime
  SO_DIEN_THOAI      String
  EMAIL              String
  DIA_CHI_THUONG_TRU String
  DIA_CHI_HIEN_TAI   String
  HINH_ANH           String?
  VECTOR_ANH         Float[]   @default([])

  SO_CCCD           String?
  NGAY_CAP_CCCD     DateTime?
  NOI_CAP_CCCD      String?
  NGAY_HET_HAN_CCCD DateTime?
  MA_SO_THUE        String?
  SO_BHXH           String?
  SO_BHYT           String?

  TRANG_THAI      TRANG_THAI_LAM_VIEC @default(DANG_LAM_VIEC)
  HINH_THUC       HINH_THUC_LAM_VIEC  @default(TOAN_THOI_GIAN)
  CHUC_VU         String?
  PHONGBAN        String?
  ID_NGUOI_DUNG   String?             @db.ObjectId
  NGUOI_DUNG      NGUOI_DUNG?         @relation(fields: [ID_NGUOI_DUNG], references: [ID_NGUOI_DUNG])
  NGAY_THU_VIEC   DateTime?
  NGAY_CHINH_THUC DateTime?
  NGAY_NGHI_VIEC  DateTime?

  DS_DU_AN_CT DS_DU_AN_CT[] @relation("PhanBoCtd")
  DS_DU_AN_CT_PHU_TRACH DS_DU_AN_CT[] @relation("PhuTrach")
  
  hoTroCtdIds String[]
  DS_DU_AN_CT_HO_TRO DS_DU_AN_CT[] @relation("HoTro", fields: [hoTroCtdIds], references: [ID_DU_AN_CT])
  
  DS_DU_AN_CT_LEADER DS_DU_AN_CT[] @relation("Leader")
  
  duyTriCtdIds String[]
  DS_DU_AN_CT_DUY_TRI DS_DU_AN_CT[] @relation("DuyTri", fields: [duyTriCtdIds], references: [ID_DU_AN_CT])

  @@index([HO_VA_TEN])
  @@index([EMAIL])
  @@index([PHONGBAN])
}

model LOAI_DU_AN {
  ID_LOAI_DU_AN String  @id @map("_id")
  LOAI_DU_AN    String
  HIEU_LUC      Boolean @default(true)

  NHOM_DU_AN NHOM_DU_AN[]
  DS_DU_AN   DS_DU_AN[]
}

model NHOM_DU_AN {
  ID_NHOM_DU_AN  String     @id @map("_id")
  ID_LOAI_DU_AN  String
  LOAI_DU_AN_REL LOAI_DU_AN @relation(fields: [ID_LOAI_DU_AN], references: [ID_LOAI_DU_AN])

  NHOM_DU_AN String
  HIEU_LUC   Boolean @default(true)

  LEVEL_DU_AN LEVEL_DU_AN[]
  CONG_VIEC   CONG_VIEC[]

  dsDuAnIds String[]
  DS_DU_AN  DS_DU_AN[] @relation(fields: [dsDuAnIds], references: [ID_DU_AN])

  DS_DU_AN_CT DS_DU_AN_CT[]
}

model LEVEL_DU_AN {
  ID_LEVEL       String     @id @default(auto()) @map("_id") @db.ObjectId
  ID_NHOM_DU_AN  String
  NHOM_DU_AN_REL NHOM_DU_AN @relation(fields: [ID_NHOM_DU_AN], references: [ID_NHOM_DU_AN])

  LEVEL         String
  MUC_TU        Float
  MUC_DEN       Float
  DIEN_GIAI     String?
  HE_SO         Float
  DINH_MUC_NGAY Float
  HIEU_LUC      Boolean @default(true)
}

model CONG_VIEC {
  ID_CONG_VIEC   String     @id @map("_id")
  ID_NHOM_DU_AN  String
  NHOM_DU_AN_REL NHOM_DU_AN @relation(fields: [ID_NHOM_DU_AN], references: [ID_NHOM_DU_AN])

  CONG_VIEC     String
  CHI_TIET      String?
  DINH_MUC_NGAY Float
  HIEU_LUC      Boolean @default(true)
}

model PHU_LUC_HOP_DONG {
  ID_PLHD              String  @id @map("_id")
  TEN_DOI_TAC_VIET_TAT String
  HIEU_LUC             Boolean @default(true)

  DS_DU_AN DS_DU_AN[]
}

model DS_DU_AN {
  ID_DU_AN   String   @id @map("_id")
  NGAY_DU_AN DateTime

  ID_LOAI_DU_AN String
  LOAI_DU_AN    LOAI_DU_AN @relation(fields: [ID_LOAI_DU_AN], references: [ID_LOAI_DU_AN])

  ID_PLHD String
  PLHD    PHU_LUC_HOP_DONG @relation(fields: [ID_PLHD], references: [ID_PLHD])

  DOI_TAC String

  nhomDuAnIds String[]
  NHOM_DU_AN  NHOM_DU_AN[] @relation(fields: [nhomDuAnIds], references: [ID_NHOM_DU_AN])

  NGAY_DK_BAT_DAU    DateTime
  NGAY_DK_HOAN_THANH DateTime
  THUC_TE            String?

  DS_DU_AN_CT DS_DU_AN_CT[]
}

model DS_HANG_MUC {
  ID_HANG_MUC  String  @id @default(auto()) @map("_id") @db.ObjectId
  TEN_HANG_MUC String
  HIEU_LUC     Boolean @default(true)

  DS_DU_AN_CT DS_DU_AN_CT[]
}

type BangChung {
  TEN_DANH_MUC String
  LINK         String
  GHI_CHU      String?
}

model DS_DU_AN_CT {
  ID_DU_AN_CT String @id @map("_id")

  ID_DU_AN String
  DU_AN    DS_DU_AN @relation(fields: [ID_DU_AN], references: [ID_DU_AN])

  ID_NHOM_DU_AN  String
  NHOM_DU_AN_REL NHOM_DU_AN @relation(fields: [ID_NHOM_DU_AN], references: [ID_NHOM_DU_AN])

  TEN_DU_AN_CT String

  ID_HANG_MUC  String      @db.ObjectId
  HANG_MUC_REL DS_HANG_MUC @relation(fields: [ID_HANG_MUC], references: [ID_HANG_MUC])

  PHAN_BO_ID  String?    @db.ObjectId
  PHAN_BO_REL NHAN_VIEN? @relation("PhanBoCtd", fields: [PHAN_BO_ID], references: [ID_NHAN_VIEN])

  // --- 1. NHÓM PHÂN BỔ ---
  EMAIL_SO_HUU String?
  
  NV_PHU_TRACH_ID String? @db.ObjectId
  NV_PHU_TRACH_REL NHAN_VIEN? @relation("PhuTrach", fields: [NV_PHU_TRACH_ID], references: [ID_NHAN_VIEN])
  
  nvHoTroIds String[] @db.ObjectId
  NV_HO_TRO_REL NHAN_VIEN[] @relation("HoTro", fields: [nvHoTroIds], references: [ID_NHAN_VIEN])
  
  LEADER_ID String? @db.ObjectId
  LEADER_REL NHAN_VIEN? @relation("Leader", fields: [LEADER_ID], references: [ID_NHAN_VIEN])
  
  DEADLINE DateTime?

  // --- 2. NHÓM TREO THƯỞNG ---
  TREO_THUONG_SO_TIEN Float?
  TREO_THUONG_THOI_HAN DateTime?

  // --- 3. NHÓM BẰNG CHỨNG ---
  BANG_CHUNG BangChung[]

  // --- 4. NHÓM NHÂN SỰ DUY TRÌ ---
  nhanSuDuyTriIds String[] @db.ObjectId
  NHAN_SU_DUY_TRI_REL NHAN_VIEN[] @relation("DuyTri", fields: [nhanSuDuyTriIds], references: [ID_NHAN_VIEN])
  
  DUY_TRI_HIEU_LUC Boolean @default(true)
}
